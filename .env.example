# === Shared ===
APP_ENV=development
LOG_LEVEL=INFO

# === RAG Agent ===
# Provider defaults (used when env vars are unset): hosted_vllm
RAG_TEXT_PROVIDER=hosted_vllm
RAG_TEXT_MODEL=gpt-4o-mini
RAG_TEXT_API_BASE=http://localhost:8000/v1
RAG_TEXT_API_KEY=
RAG_TEXT_TEMPERATURE=0.2
RAG_TEXT_MAX_TOKENS=1800

RAG_VLM_PROVIDER=hosted_vllm
RAG_VLM_MODEL=gpt-4o-mini
RAG_VLM_API_BASE=http://localhost:8000/v1
RAG_VLM_API_KEY=
RAG_VLM_TEMPERATURE=0.1
RAG_VLM_MAX_TOKENS=600
RAG_VLM_BATCH_SIZE=4

RAG_EMBEDDING_PROVIDER=hosted_vllm
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_EMBEDDING_API_BASE=http://localhost:8000/v1
RAG_EMBEDDING_API_KEY=
RAG_EMBEDDING_MAX_TOKENS=1024

# === Planner Agent ===
# Add planner-specific variables here.

# === Teaching Agent ===
